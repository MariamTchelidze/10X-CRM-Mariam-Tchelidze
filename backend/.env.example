PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://your_database_user:your_url_encoded_password@your_cluster.mongodb.net/your_database_name?appName=your_cluster_name
CLIENT_URL=http://127.0.0.1:5500,http://localhost:5500,https://your-production-domain.com
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
ALLOWED_CALL_NUMBER=
